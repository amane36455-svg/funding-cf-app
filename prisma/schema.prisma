generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       =  env("APP_DATABASE_URL")
  directUrl =  env("APP_DIRECT_URL")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique
  name         String?
  passwordHash String        @map("password_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  memberships  UserCompany[]
  companies    Company[]     @relation("CompanyOwner")
  preference   UserPreference?
  documents    GeneratedDocument[]
  importedFiles ImportedFile[] @relation("ImportedFileUploader")
  importBatches ImportBatch[]  @relation("ImportBatchCreator")

  @@map("users")
}

model Company {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  ownerUserId        String              @map("owner_user_id") @db.Uuid
  companyType        String?             @map("company_type")
  status             String              @default("active")
  fiscalMonth        Int?                @map("fiscal_month")
  industry           String?
  memo               String?             @db.Text
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  owner              User                @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  memberships        UserCompany[]
  currentPreferences UserPreference[]    @relation("CurrentCompanyPreference")
  mfConnection       MfConnection?
  mfAccounts         MfAccount[]
  mfJournals         MfJournal[]
  mfJournalDetails   MfJournalDetail[]
  cfRules            CfClassificationRule[]
  cfResults          CfClassificationResult[]
  documents          GeneratedDocument[]
  syncHistories      MfSyncHistory[]
  importedFiles      ImportedFile[]
  importBatches      ImportBatch[]
  journalEntries     JournalEntry[]
  journalEntryLines  JournalEntryLine[]

  @@index([status])
  @@index([industry])
  @@map("companies")
}

enum CompanyRole {
  OWNER
  ADMIN
  STAFF
  REVIEWER
  VIEWER
  MEMBER
}

enum ImportFileKind {
  CSV
  EXCEL
}

enum ImportBatchStatus {
  DRAFT
  NEEDS_REVIEW
  CANCELLED
}

enum JournalEntryStatus {
  DRAFT
  NEEDS_REVIEW
}

enum JournalEntryLineSide {
  DEBIT
  CREDIT
}

model UserCompany {
  userId         String      @map("user_id") @db.Uuid
  companyId      String      @map("company_id") @db.Uuid
  role           CompanyRole @default(STAFF)
  isFavorite     Boolean     @default(false) @map("is_favorite")
  lastAccessedAt DateTime?   @map("last_accessed_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
  @@index([userId, isFavorite])
  @@index([userId, lastAccessedAt])
  @@map("user_companies")
}

model UserPreference {
  userId           String   @id @map("user_id") @db.Uuid
  currentCompanyId String?  @map("current_company_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentCompany   Company? @relation("CurrentCompanyPreference", fields: [currentCompanyId], references: [id], onDelete: SetNull)

  @@index([currentCompanyId])
  @@map("user_preferences")
}

model ImportedFile {
  id               String       @id @default(uuid()) @db.Uuid
  companyId        String       @map("company_id") @db.Uuid
  uploadedByUserId String       @map("uploaded_by_user_id") @db.Uuid
  originalFilename String       @map("original_filename")
  fileKind         ImportFileKind @map("file_kind")
  encoding         String?
  sheetName        String?      @map("sheet_name")
  fileSizeBytes    Int          @map("file_size_bytes")
  storageRef       String?      @map("storage_ref")
  previewSnapshot  Json?        @map("preview_snapshot")
  createdAt        DateTime     @default(now()) @map("created_at")
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy       User         @relation("ImportedFileUploader", fields: [uploadedByUserId], references: [id])
  batches          ImportBatch[]

  @@index([companyId, createdAt])
  @@index([companyId, uploadedByUserId])
  @@map("imported_files")
}

model ImportBatch {
  id                  String            @id @default(uuid()) @db.Uuid
  companyId           String            @map("company_id") @db.Uuid
  importedFileId      String            @map("imported_file_id") @db.Uuid
  createdByUserId     String            @map("created_by_user_id") @db.Uuid
  status              ImportBatchStatus @default(DRAFT)
  readyRowCount       Int               @default(0) @map("ready_row_count")
  needsReviewRowCount Int               @default(0) @map("needs_review_row_count")
  skippedRowCount     Int               @default(0) @map("skipped_row_count")
  mappingSnapshot     Json              @map("mapping_snapshot")
  validationSummary   Json?             @map("validation_summary")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  company             Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  importedFile        ImportedFile      @relation(fields: [importedFileId], references: [id], onDelete: Cascade)
  createdBy           User              @relation("ImportBatchCreator", fields: [createdByUserId], references: [id])
  journalEntries      JournalEntry[]

  @@index([companyId, status])
  @@index([companyId, importedFileId])
  @@index([companyId, createdByUserId])
  @@index([companyId, createdAt])
  @@map("import_batches")
}

model JournalEntry {
  id              String             @id @default(uuid()) @db.Uuid
  companyId       String             @map("company_id") @db.Uuid
  importBatchId   String             @map("import_batch_id") @db.Uuid
  sourceRowNumber Int                @map("source_row_number")
  tradeDate       DateTime           @map("trade_date") @db.Date
  description     String?            @db.Text
  status          JournalEntryStatus @default(DRAFT)
  rawRowSummary   Json?              @map("raw_row_summary")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  importBatch     ImportBatch        @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  lines           JournalEntryLine[]

  @@unique([companyId, importBatchId, sourceRowNumber])
  @@index([companyId, importBatchId])
  @@index([companyId, tradeDate])
  @@index([companyId, status])
  @@map("journal_entries")
}

model JournalEntryLine {
  id               String               @id @default(uuid()) @db.Uuid
  companyId        String               @map("company_id") @db.Uuid
  journalEntryId   String               @map("journal_entry_id") @db.Uuid
  lineNo           Int                  @map("line_no")
  side             JournalEntryLineSide
  accountName      String               @map("account_name")
  subAccountName   String?              @map("sub_account_name")
  departmentName   String?              @map("department_name")
  taxCategory      String?              @map("tax_category")
  amount           Decimal              @db.Decimal(18, 2)
  createdAt        DateTime             @default(now()) @map("created_at")
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalEntry     JournalEntry         @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([companyId, journalEntryId])
  @@index([companyId, side])
  @@map("journal_entry_lines")
}

model MfConnection {
  id              String    @id @default(uuid()) @db.Uuid
  companyId       String    @unique @map("company_id") @db.Uuid
  mfOfficeId      String?   @map("mf_office_id")
  accessTokenEnc  Bytes     @map("access_token_enc")
  refreshTokenEnc Bytes     @map("refresh_token_enc")
  tokenExpiresAt  DateTime  @map("token_expires_at")
  scope           String?
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("mf_connections")
}

model MfAccount {
  id          String            @id @default(uuid()) @db.Uuid
  companyId   String            @map("company_id") @db.Uuid
  mfAccountId String            @map("mf_account_id")
  name        String
  category    String?
  subCategory String?           @map("sub_category")
  excise      String?
  rawJson     Json              @map("raw_json")
  updatedAtMf DateTime?         @map("updated_at_mf")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  details     MfJournalDetail[]

  @@unique([companyId, mfAccountId])
  @@index([companyId, name])
  @@map("mf_accounts")
}

model MfJournal {
  id          String            @id @default(uuid()) @db.Uuid
  companyId   String            @map("company_id") @db.Uuid
  mfJournalId String            @map("mf_journal_id")
  issueDate   DateTime          @map("issue_date") @db.Date
  slipNumber  String?           @map("slip_number")
  description String?
  tagNames    String[]          @map("tag_names")
  totalAmount BigInt            @map("total_amount")
  rawJson     Json              @map("raw_json")
  updatedAtMf DateTime?         @map("updated_at_mf")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  details     MfJournalDetail[]

  @@unique([companyId, mfJournalId])
  @@index([companyId, issueDate])
  @@map("mf_journals")
}

model MfJournalDetail {
  id             String                  @id @default(uuid()) @db.Uuid
  companyId      String                  @map("company_id") @db.Uuid
  journalId      String                  @map("journal_id") @db.Uuid
  mfDetailId     String                  @map("mf_detail_id")
  side           String
  accountId      String?                 @map("account_id") @db.Uuid
  subAccountName String?                 @map("sub_account_name")
  amount         BigInt
  taxAmount      BigInt?                 @map("tax_amount")
  description    String?
  rawJson        Json                    @map("raw_json")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journal        MfJournal               @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account        MfAccount?              @relation(fields: [accountId], references: [id])
  cfResult       CfClassificationResult?

  @@unique([companyId, mfDetailId])
  @@index([companyId, journalId])
  @@index([companyId, accountId])
  @@map("mf_journal_details")
}

model CfClassificationRule {
  id         String                   @id @default(uuid()) @db.Uuid
  companyId  String?                  @map("company_id") @db.Uuid
  priority   Int                      @default(100)
  matchType  String                   @map("match_type")
  matchValue String                   @map("match_value")
  cfCategory String                   @map("cf_category")
  cfGroup    String                   @map("cf_group")
  isPersonal Boolean                  @default(false) @map("is_personal")
  enabled    Boolean                  @default(true)
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")
  company    Company?                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  results    CfClassificationResult[]

  @@index([companyId, enabled, priority])
  @@map("cf_classification_rules")
}

model CfClassificationResult {
  id                 String                @id @default(uuid()) @db.Uuid
  companyId          String                @map("company_id") @db.Uuid
  journalDetailId    String                @unique @map("journal_detail_id") @db.Uuid
  cfCategory         String                @map("cf_category")
  cfGroup            String                @map("cf_group")
  isPersonal         Boolean               @default(false) @map("is_personal")
  needsReview        Boolean               @default(false) @map("needs_review")
  appliedRuleId      String?               @map("applied_rule_id") @db.Uuid
  reason             String?
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalDetail      MfJournalDetail       @relation(fields: [journalDetailId], references: [id], onDelete: Cascade)
  appliedRule        CfClassificationRule? @relation(fields: [appliedRuleId], references: [id])

  @@index([companyId, needsReview])
  @@index([companyId, cfGroup])
  @@map("cf_classification_results")
}

model GeneratedDocument {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  kind         String
  status       String   @default("draft")
  inputsJson   Json     @map("inputs_json")
  snapshotJson Json     @map("snapshot_json")
  bodyMarkdown String   @map("body_markdown") @db.Text
  model        String?
  createdById  String   @map("created_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User     @relation(fields: [createdById], references: [id])

  @@index([companyId, createdAt])
  @@map("generated_documents")
}

model MfSyncHistory {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  kind             String
  status           String
  startedAt        DateTime  @default(now()) @map("started_at")
  finishedAt       DateTime? @map("finished_at")
  targetRangeFrom  DateTime? @map("target_range_from") @db.Date
  targetRangeTo    DateTime? @map("target_range_to") @db.Date
  journalsUpserted Int       @default(0) @map("journals_upserted")
  detailsUpserted  Int       @default(0) @map("details_upserted")
  errorJson        Json?     @map("error_json")
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, startedAt])
  @@map("mf_sync_history")
}
