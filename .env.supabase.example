NEXTAUTH_URL=https://your-vercel-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-vercel-app.vercel.app
NEXTAUTH_SECRET=replace_me_32_chars_or_more
TOKEN_ENCRYPTION_KEY=replace_me_32_byte_base64

# Supabase
# Runtime should use Supavisor/Pooler transaction connection.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Migrations should use direct/session connection.
DIRECT_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# MF OAuth
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_REDIRECT_URI=https://your-vercel-app.vercel.app/api/auth/mf/callback
MF_AUTHORIZE_URL=https://api.biz.moneyforward.com/authorize
MF_TOKEN_URL=https://api.biz.moneyforward.com/token
MF_API_BASE_URL=https://api-accounting.moneyforward.com
MF_SCOPES=
MF_PATH_OFFICES=/api/v3/offices
MF_PATH_ACCOUNTS=/api/v3/accounts
MF_PATH_JOURNALS=/api/v3/journals
MF_QUERY_OFFICE_ID=
MF_QUERY_PAGE=page
MF_QUERY_PER_PAGE=per_page
MF_QUERY_JOURNALS_FROM=start_date
MF_QUERY_JOURNALS_TO=end_date
MF_ACCOUNTS_PAGINATED=false

# Generation
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Cron
CRON_SECRET=replace_me_random_secret

# PDF
PUPPETEER_EXECUTABLE_PATH=
CHROMIUM_DOWNLOAD_URL=

LOG_LEVEL=info
