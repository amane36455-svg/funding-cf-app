DATABASE_URL=postgresql://postgres:postgres@localhost:5432/funding_cf?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/funding_cf?schema=public
NEXTAUTH_SECRET=replace_me_with_32byte_secret
# TOKEN_ENCRYPTION_KEY must be standard base64 for exactly 32 random bytes.
# Generate with: pnpm gen:key
# In Vercel, paste only the value after TOKEN_ENCRYPTION_KEY= and never commit the real value.
TOKEN_ENCRYPTION_KEY=replace_me_with_base64_encoded_32_bytes
MF_CLIENT_ID=
MF_CLIENT_SECRET=
MF_REDIRECT_URI=http://localhost:3000/api/auth/mf/callback
MF_AUTHORIZE_URL=https://api.biz.moneyforward.com/authorize
MF_TOKEN_URL=https://api.biz.moneyforward.com/token
MF_API_BASE_URL=https://api-accounting.moneyforward.com
MF_SCOPES=
MF_PATH_OFFICES=/api/v3/offices
MF_PATH_ACCOUNTS=/api/v3/accounts
MF_PATH_JOURNALS=/api/v3/journals
MF_QUERY_OFFICE_ID=
MF_QUERY_PAGE=page
MF_QUERY_PER_PAGE=per_page
MF_QUERY_JOURNALS_FROM=start_date
MF_QUERY_JOURNALS_TO=end_date
MF_ACCOUNTS_PAGINATED=false
LOG_LEVEL=info
CRON_SECRET=replace_me_random_string
PUPPETEER_EXECUTABLE_PATH=
CHROMIUM_DOWNLOAD_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
