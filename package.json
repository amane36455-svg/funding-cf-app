{
  "name": "funding-cf-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
   "build": "pnpm db:generate && pnpm db:migrate:deploy && node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "node scripts/run-prisma.mjs migrate dev",
    "db:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "db:migrate:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "db:generate": "node scripts/run-prisma.mjs generate",
    "db:studio": "node scripts/run-prisma.mjs studio",
    "gen:key": "tsx scripts/generate-encryption-key.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx scripts/seed-demo-data.ts",
    "check:env": "node scripts/check-env.mjs",
    "check:env:prod": "node scripts/check-env.mjs --production",
    "check:db": "tsx scripts/check-db.ts",
    "smoke": "node scripts/smoke.mjs",
    "smoke:local": "node scripts/smoke.mjs http://localhost:3000",
    "audit:api-scope": "node scripts/audit-api-scope.mjs",
    "db:local:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-local-postgres.ps1",
    "db:local:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "db:local:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.22.0",
    "@sparticuz/chromium-min": "^148.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "next": "14.2.35",
    "next-auth": "^4.24.10",
    "pino": "^9.5.0",
    "puppeteer-core": "^23.6.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
